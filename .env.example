# Claudable server config — copy to /opt/claudable/.env on box1 (DO NOT COMMIT).

# --- Agent auth: run claude -p with your Claude subscription (no API billing) ---
# Generate once with `claude setup-token` on a logged-in machine, paste here.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Git provider (self-hosted Gitea) ---
GIT_PROVIDER=gitea
GIT_API_BASE_URL=https://git.newstory.tf/api/v1
GIT_HTTP_BASE=https://git.newstory.tf
GIT_ORG=newstory-org
GIT_DEPLOY_DOMAIN=newstory.tf
# Gitea API token (write:repository, write:organization). Used for repo create + push.
GIT_TOKEN=

# --- App ---
DATABASE_URL=file:../data/cc.db
PROJECTS_DIR=./data/projects
WEB_PORT=3700
