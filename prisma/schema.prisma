// Claudable - Prisma Schema (SQLite)
// Supports both development and production using SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"

}

// ============================================================
// Core Models
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("idle") // idle, running, stopped, error

  // Preview (legacy metadata retained for compatibility)
  previewUrl  String?  @map("preview_url")
  previewPort Int?     @map("preview_port")

  // Repository
  repoPath    String?  @map("repo_path")

  // Initial setup
  initialPrompt String? @map("initial_prompt")
  templateType  String? @map("template_type") // nextjs, react, vue, etc.

  // AI Session Management
  activeClaudeSessionId String? @map("active_claude_session_id")
  activeCursorSessionId String? @map("active_cursor_session_id")

  // CLI Preferences
  preferredCli  String? @map("preferred_cli") // claude, cursor, codex, gemini, qwen
  selectedModel String? @map("selected_model") // claude model id (claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001)
  fallbackEnabled Boolean @default(false) @map("fallback_enabled")

  // Settings (JSON)
  settings    String? // JSON string for additional settings

  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")

  // Access control
  orgId      String? @map("org_id")
  ownerId    String? @map("owner_id")
  visibility String  @default("org") // org | restricted

  // Who last ran an agent turn / edit on this project (for the homepage tile).
  // Distinct from ownerId (the creator). Null until the first turn under auth.
  lastEditedById String? @map("last_edited_by_id")

  // Which Claude credential the agent runs with (null = global env token).
  claudeCredentialId String? @map("claude_credential_id")

  // Admin-only: expose the shared it-ops MCP tools to this project's agent.
  itopsEnabled Boolean @default(false) @map("itops_enabled")

  // Relations
  messages              Message[]
  sessions              Session[]
  envVars               EnvVar[]
  serviceConnections    ProjectServiceConnection[]
  commits               Commit[]
  toolUsages            ToolUsage[]
  userRequests          UserRequest[]
  comments              Comment[]
  shares                ProjectShare[]
  mcpServers            ProjectMcpServer[]
  designCanvases        DesignCanvas[]
  organization          Organization?  @relation(fields: [orgId], references: [id])
  owner                 User?          @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: SetNull)
  lastEditedBy          User?          @relation("EditedProjects", fields: [lastEditedById], references: [id], onDelete: SetNull)
  members               ProjectMember[]
  claudeCredential      ClaudeCredential? @relation("ProjectClaudeCredential", fields: [claudeCredentialId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@map("projects")
}

/// Review comments pinned to a spot on the previewed site. Claudable-only (never
/// touches the app source), scoped per route, anchored to an element + offset.
model Comment {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  route          String
  anchorSelector String   @map("anchor_selector")
  relX           Float // 0..1 within the anchor element's box
  relY           Float
  body           String
  resolved       Boolean  @default(false)
  authorId       String?  @map("author_id")
  authorName     String?  @map("author_name") // snapshot at create time (survives author deletion)
  mentionsJson   String?  @map("mentions_json") // JSON [{id,name}] — users @-tagged in the body (names snapshotted)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId, route])
  @@map("comments")
}

/// A revocable public link that lets a stakeholder view the live preview and leave
/// pinned comments without a Claudable account (read + comment only).
model ProjectShare {
  id        String   @id @default(cuid())
  projectId String   @unique @map("project_id")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_shares")
}

// ============================================================
// Auth & Access Control
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users    User[]
  projects Project[]

  @@map("organizations")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  image       String?
  role        String    @default("user") // admin | user
  isActive    Boolean   @default(true) @map("is_active")
  // When true, the it-ops MCP broker attaches for every project this user owns
  // (admins self-enable; admins can also enable it for others). See claude.ts.
  itopsEnabled Boolean  @default(false) @map("itops_enabled")
  // Preferred UI language (i18n locale code, e.g. 'en','nl'); null = follow the
  // browser/localStorage default. Set from Settings → General, per user.
  locale      String?
  orgId       String    @map("org_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  organization  Organization    @relation(fields: [orgId], references: [id])
  ownedProjects Project[]       @relation("OwnedProjects")
  editedProjects Project[]      @relation("EditedProjects")
  memberships   ProjectMember[]
  claudeCredentials ClaudeCredential[]
  comments      Comment[]

  @@index([orgId])
  @@map("users")
}

/**
 * A user's Claude Code subscription token (from `claude setup-token`), stored
 * encrypted (lib/crypto). Owner-only by default; `shareable` lets other users in
 * the org select it for a project. A project's runs use its assigned credential
 * (Project.claudeCredentialId), falling back to the global env token.
 */
model ClaudeCredential {
  id         String    @id @default(cuid())
  ownerId    String    @map("owner_id")
  label      String
  token      String // encrypted
  shareable  Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects Project[] @relation("ProjectClaudeCredential")

  @@index([ownerId])
  @@map("claude_credentials")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("editor") // viewer | editor
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Message {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")

  // Message content
  role         String // user, assistant, system, tool
  messageType  String @map("message_type") // chat, thinking, tool_use, tool_result, error
  content      String // Message content (text, markdown, code)
  metadataJson String? @map("metadata_json") // JSON string for tool info, etc.

  // Thread support
  parentMessageId String? @map("parent_message_id")

  // Session
  sessionId      String? @map("session_id")
  conversationId String? @map("conversation_id")

  // Performance tracking
  durationMs Int? @map("duration_ms")
  tokenCount Int? @map("token_count")
  costUsd    Float? @map("cost_usd")

  // Git integration
  commitSha String? @map("commit_sha")

  // CLI source
  cliSource String? @map("cli_source") // claude, cursor, etc.

  // Request ID for client-server message matching
  requestId String? @map("request_id")

  // Timestamp
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])
  toolUsages ToolUsage[]

  @@index([projectId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([cliSource])
  @@index([requestId])
  // Serves the hot history query: WHERE projectId ORDER BY createdAt.
  @@index([projectId, createdAt])
  @@map("messages")
}

model Session {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")

  // Session info
  sessionType String   @map("session_type") // chat, code_gen, error_fix
  cliType     String   @map("cli_type") // claude, cursor, codex, gemini, qwen
  sessionId   String   @map("session_id") // Actual CLI session ID
  modelName   String?  @map("model_name")

  // Context
  contextTokens Int?   @map("context_tokens")

  // Status
  status    String   @default("active") // active, ended, error

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  endedAt   DateTime? @map("ended_at")

  // Relations
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([projectId])
  @@index([cliType])
  @@map("sessions")
}

model ProjectServiceConnection {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")

  // Service info
  provider     String // github, vercel, supabase
  status       String @default("connected") // connected, disconnected, error

  // Service data (JSON)
  // GitHub: { repo_url, repo_name, default_branch }
  // Vercel: { deployment_url, project_id, auto_deploy }
  // Supabase: { project_url, project_id, database_name }
  serviceData  String @map("service_data")

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  lastSyncAt  DateTime? @map("last_sync_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([provider])
  @@map("project_service_connections")
}

// Per-project MCP servers the agent gets access to (in addition to the built-in
// brokered ones). Generic: http/sse remote servers or stdio command servers.
// Secrets (auth headers / stdio env) are encrypted at rest via lib/crypto.
/**
 * Org-shared MCP servers: an admin registers a server once and every project's
 * agent in the org (or instance-wide when orgId is null) gets it automatically —
 * no per-project setup. Shared servers use a SHARED credential (static auth
 * header / stdio env), not per-user OAuth, since the whole team uses them. See
 * lib/services/shared-mcp.ts.
 */
model SharedMcpServer {
  id        String   @id @default(cuid())
  // Null = instance-wide (all projects, incl. auth-off single-tenant). Set =
  // only projects in that org. Scalar (no relation) to keep this table isolated.
  orgId     String?  @map("org_id")

  name      String   // mcpServers map key — [a-z0-9_-]
  label     String
  transport String   // http | sse | stdio
  url       String?
  command   String?
  argsJson  String?  @map("args_json")
  headersEncrypted String? @map("headers_encrypted") // encrypted JSON: shared auth headers (http/sse)
  envEncrypted     String? @map("env_encrypted")     // encrypted JSON: env (stdio)
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, name])
  @@index([orgId])
  @@map("shared_mcp_servers")
}

// A registered Claude Code plugin MARKETPLACE (a git repo with
// .claude-plugin/marketplace.json). Org-wide like SharedMcpServer: orgId null =
// instance-wide (all projects). Claudable clones the repo in the CONTROL PLANE
// (auth token never enters the sandbox), sanitizes it, and mounts the plugin
// dirs read-only into each agent turn, loading enabled plugins via the CLI's
// own `--plugin-dir` flag. Per-project opt-out lives in a project state file
// (mirrors the skills subsystem), not here.
model PluginMarketplace {
  id        String   @id @default(cuid())
  orgId     String?  @map("org_id")

  name      String   // marketplace id (from marketplace.json "name"); slug used as the on-disk dir
  gitUrl    String   @map("git_url")            // https git URL of the marketplace repo
  ref       String?                             // optional branch/tag/sha to pin
  subpath   String?                             // optional path within the repo to the marketplace root
  // Git host whose ServiceToken authenticates the clone (private repos). The
  // token is read in the control plane and embedded in the remote URL, exactly
  // like git push — it never reaches the agent container.
  tokenProvider String @default("github") @map("token_provider")
  enabled   Boolean  @default(true)

  // The plugins' bundled MCP servers ship platform-specific binaries (e.g.
  // darwin-arm64) that can't run in the linux agent sandbox and may hang on
  // autoInstall, so their .mcp.json is stripped from the synced copy by default.
  // Opt in only if a marketplace's MCP servers are known to work in-container.
  includeMcpServers Boolean @default(false) @map("include_mcp_servers")

  // Parsed at sync time from marketplace.json: JSON array of
  // {name, source, description, version}. The catalog of installable plugins.
  catalogJson String? @map("catalog_json")
  // JSON string[] of plugin names enabled org-wide (default: all in the catalog).
  enabledPluginsJson String? @map("enabled_plugins_json")

  lastSyncedAt  DateTime? @map("last_synced_at")
  lastSyncError String?   @map("last_sync_error")
  syncedRef     String?   @map("synced_ref") // commit sha actually checked out

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, name])
  @@index([orgId])
  @@map("plugin_marketplaces")
}

model ProjectMcpServer {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  // Visibility within the project. Null = SHARED: every project member's agent
  // runs get it. Set = PRIVATE: only that user's own agent runs get it (added by
  // them, invisible to other members). Lets a user wire a personal account (e.g.
  // their own Gmail MCP) without exposing it to the whole team.
  ownerId   String?  @map("owner_id")

  name      String   // mcpServers map key, e.g. "relume" — [a-z0-9_-]
  label     String   // human label shown in the UI
  transport String   // http | sse | stdio
  url       String?  // http/sse endpoint
  command   String?  // stdio command, e.g. "npx"
  argsJson  String?  @map("args_json")           // JSON string[] for stdio args
  headersEncrypted String? @map("headers_encrypted") // encrypted JSON: auth headers (http/sse)
  envEncrypted     String? @map("env_encrypted")     // encrypted JSON: env (stdio)
  enabled   Boolean  @default(true)

  // OAuth (MCP authorization spec, OAuth 2.1 + PKCE + DCR). When authType='oauth'
  // the agent gets `Authorization: Bearer <token>` injected at turn build time.
  authType             String? @map("auth_type")               // null|"none"|"oauth"
  oauthMetadataJson    String? @map("oauth_metadata_json")     // {authorization_endpoint, token_endpoint, registration_endpoint, resource, scopes}
  oauthClientId        String? @map("oauth_client_id")
  oauthClientSecretEnc String? @map("oauth_client_secret_enc") // encrypted (confidential clients only)
  oauthTokensEnc       String? @map("oauth_tokens_enc")        // encrypted JSON {access_token, refresh_token, expires_at, scope, token_type}
  oauthPkceEnc         String? @map("oauth_pkce_enc")          // encrypted in-flight PKCE verifier (cleared after callback)
  oauthState           String? @map("oauth_state")             // in-flight CSRF state (single-use, cleared after callback)
  oauthConnectedAt     DateTime? @map("oauth_connected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Names are unique within a project across ALL visibilities (shared + every
  // user's private), so a run never has two servers mapping to the same key and
  // precedence is a non-issue. Trade-off: two users can't both name a private
  // server the same thing — the second picks a different name.
  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_mcp_servers")
}

model EnvVar {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")

  // Environment variable
  key            String
  valueEncrypted String  @map("value_encrypted") // AES-256 encrypted
  scope          String  @default("runtime") // runtime, build, preview
  varType        String  @default("string") @map("var_type") // string, number, boolean, json
  isSecret       Boolean @default(true) @map("is_secret")
  description    String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@map("env_vars")
}

model Commit {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")

  // Commit info
  sha         String
  message     String
  authorName  String  @map("author_name")
  authorEmail String  @map("author_email")

  // Timestamp
  committedAt DateTime @map("committed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([committedAt])
  @@map("commits")
}

model ToolUsage {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  messageId  String?  @map("message_id")

  // Tool info
  toolName   String   @map("tool_name") // Read, Write, Edit, Bash, etc.
  toolInput  String   @map("tool_input") // JSON string
  toolOutput String?  @map("tool_output")
  error      String?

  // Performance
  durationMs Int?     @map("duration_ms")

  // Timestamp
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id])

  @@index([projectId])
  @@index([messageId])
  @@index([toolName])
  @@map("tool_usages")
}

model UserRequest {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")

  // Request info
  instruction    String
  cliPreference  String?  @map("cli_preference")
  status         String   @default("pending") // pending, processing, completed, failed
  errorMessage   String?  @map("error_message")

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  // Serves getActiveRequests(): WHERE projectId AND status IN (...) AND createdAt >= cutoff.
  @@index([projectId, status, createdAt])
  @@map("user_requests")
}

// ============================================================
// Service Tokens (Local Development Only)
// ============================================================

model ServiceToken {
  id       String   @id @default(cuid())

  // Service info
  provider String // github, vercel, supabase
  name     String // User-defined name
  token    String // Access token, encrypted at rest via lib/crypto (iv:ciphertext)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastUsed  DateTime? @map("last_used")

  @@index([provider])
  @@map("service_tokens")
}

/// Design Explorer: a canvas of AI-generated design mockups for a project. A
/// prompt fans out into several DesignFrames the user compares/refines/uses.
model DesignCanvas {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  title              String
  prompt             String
  status             String   @default("idle") // idle | generating | ready
  referenceImagePath String?  @map("reference_image_path")
  createdById        String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  frames  DesignFrame[]

  @@index([projectId])
  @@map("design_canvases")
}

/// One generated design direction on a canvas. The mockup HTML lives on disk
/// (htmlPath) — never in the DB — so the row stays light.
model DesignFrame {
  id            String   @id @default(cuid())
  canvasId      String   @map("canvas_id")
  styleId       String?  @map("style_id")
  styleName     String?  @map("style_name")
  prompt        String
  htmlPath      String?  @map("html_path")
  status        String   @default("pending") // pending | generating | ready | error
  errorText     String?  @map("error_text")
  version       Int      @default(1)
  parentFrameId String?  @map("parent_frame_id")
  costUsd       Float?   @map("cost_usd")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  durationMs    Int?     @map("duration_ms")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  canvas DesignCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@map("design_frames")
}
